# ─────────────────────────────────────────────────────────
#  NagrikVaani — Environment Variables
#  Copy this file and rename it to .env
#  Then fill in your actual values below.
# ─────────────────────────────────────────────────────────

# Server port (default is 3000, no need to change)
PORT=3001

# Google Cloud Translation API Key
# How to get it:
#   1. Go to https://console.cloud.google.com
#   2. Create a new project (e.g. "NagrikVaani")
#   3. Go to APIs & Services > Enable APIs
#   4. Search for "Cloud Translation API" and enable it
#   5. Go to Credentials > Create Credentials > API Key
#   6. Copy the key and paste it below
#
# NOTE: Without this key, translation will be skipped
#       and the original text will be used as-is.
#       The system still works for English complaints.

GOOGLE_TRANSLATE_API_KEY=""
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=Admin@123
DB_NAME=nagrikvaani
